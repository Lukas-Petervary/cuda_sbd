# Path to the SBD library
SBD_PATH=../..

# CUDA compiler options
CUDACOM= nvcc
PROF_CUDACOM= nvcc
CUDA_ARCH= sm_60
CUDAFLAGS= -c -O3 -std=c++17 -I$(SBD_INCLUDE_DIR) -Xcompiler -fPIC -DBLOCK_SIZE=128
# CUDA_ARCH= $(shell nvcc --list-gpu-arch 2>/dev/null | head -1 | sed 's/-arch=//' || echo "sm_60")

# mpi c++ compiler
CCCOM= mpicxx
PROF_CCCOM= scorep mpicxx
# CCCOM=/opt/nvidia/hpc_sdk/Linux_x86_64/2025/comm_libs/mpi/bin/mpic++

# custom
CCFLAGS= -std=c++17 -fopenmp -O3 -DKERNEL_EXCITATION -DSBD_DEBUG_MULT
SYSLIB= -lopenblas -llapack

# flags for build: include path to openmp. The following is the case using homebrew's llvm on Mac
# CCFLAGS= -std=c++17 -stdlib=libc++ -fopenmp -I/opt/homebrew/opt/llvm/include -O3

